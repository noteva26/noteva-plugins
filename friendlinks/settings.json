{
  "sections": [
    {
      "id": "general",
      "title": {
        "zh-CN": "基本设置",
        "en": "General",
        "zh-TW": "基本設定"
      },
      "fields": [
        {
          "id": "target_slug",
          "type": "text",
          "label": {
            "zh-CN": "目标页面 Slug",
            "en": "Target Page Slug",
            "zh-TW": "目標頁面 Slug"
          },
          "default": "friendlinks",
          "description": {
            "zh-CN": "友链页面的 slug，例如：friendlinks（访问 /friendlinks 时显示友链）",
            "en": "Slug of the friend links page, e.g. friendlinks (shows at /friendlinks)",
            "zh-TW": "友鏈頁面的 slug，例如：friendlinks（存取 /friendlinks 時顯示友鏈）"
          }
        },
        {
          "id": "title",
          "type": "text",
          "label": {
            "zh-CN": "页面标题",
            "en": "Page Title",
            "zh-TW": "頁面標題"
          },
          "default": "友情链接",
          "description": {
            "zh-CN": "友链页面的标题",
            "en": "Title of the friend links page",
            "zh-TW": "友鏈頁面的標題"
          }
        },
        {
          "id": "description",
          "type": "textarea",
          "label": {
            "zh-CN": "页面描述",
            "en": "Page Description",
            "zh-TW": "頁面描述"
          },
          "default": "欢迎交换友链！",
          "description": {
            "zh-CN": "显示在友链列表上方的描述文字",
            "en": "Description text above the links list",
            "zh-TW": "顯示在友鏈列表上方的描述文字"
          }
        }
      ]
    },
    {
      "id": "links",
      "title": {
        "zh-CN": "友链列表",
        "en": "Link List",
        "zh-TW": "友鏈列表"
      },
      "fields": [
        {
          "id": "links_data",
          "label": {
            "zh-CN": "友链数据",
            "en": "Links Data",
            "zh-TW": "友鏈資料"
          },
          "type": "array",
          "description": {
            "zh-CN": "添加友情链接",
            "en": "Add friend links",
            "zh-TW": "新增友情連結"
          },
          "default": [
            {
              "name": "Noteva 官网",
              "url": "https://github.com/noteva26/noteva",
              "logo": "",
              "description": "轻量级博客系统",
              "category": "推荐"
            }
          ],
          "itemFields": [
            {
              "id": "name",
              "label": {
                "zh-CN": "站点名称",
                "en": "Site Name",
                "zh-TW": "站點名稱"
              },
              "type": "text",
              "placeholder": {
                "zh-CN": "站点名称",
                "en": "Site name",
                "zh-TW": "站點名稱"
              },
              "required": true
            },
            {
              "id": "url",
              "label": {
                "zh-CN": "站点链接",
                "en": "Site URL",
                "zh-TW": "站點連結"
              },
              "type": "text",
              "placeholder": "https://example.com",
              "required": true
            },
            {
              "id": "logo",
              "label": "Logo URL",
              "type": "text",
              "placeholder": {
                "zh-CN": "Logo 图片 URL（可选）",
                "en": "Logo image URL (optional)",
                "zh-TW": "Logo 圖片 URL（可選）"
              }
            },
            {
              "id": "description",
              "label": {
                "zh-CN": "站点描述",
                "en": "Description",
                "zh-TW": "站點描述"
              },
              "type": "text",
              "placeholder": {
                "zh-CN": "站点描述（可选）",
                "en": "Description (optional)",
                "zh-TW": "站點描述（可選）"
              }
            },
            {
              "id": "category",
              "label": {
                "zh-CN": "分类",
                "en": "Category",
                "zh-TW": "分類"
              },
              "type": "text",
              "placeholder": {
                "zh-CN": "分类名称（可选）",
                "en": "Category (optional)",
                "zh-TW": "分類名稱（可選）"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "style",
      "title": {
        "zh-CN": "样式设置",
        "en": "Style",
        "zh-TW": "樣式設定"
      },
      "fields": [
        {
          "id": "layout",
          "type": "select",
          "label": {
            "zh-CN": "布局方式",
            "en": "Layout",
            "zh-TW": "佈局方式"
          },
          "default": "grid",
          "options": [
            {
              "value": "grid",
              "label": {
                "zh-CN": "网格布局",
                "en": "Grid",
                "zh-TW": "網格佈局"
              }
            },
            {
              "value": "list",
              "label": {
                "zh-CN": "列表布局",
                "en": "List",
                "zh-TW": "列表佈局"
              }
            }
          ]
        },
        {
          "id": "columns",
          "type": "number",
          "label": {
            "zh-CN": "每行显示数量",
            "en": "Columns Per Row",
            "zh-TW": "每行顯示數量"
          },
          "default": 3,
          "min": 1,
          "max": 6,
          "description": {
            "zh-CN": "仅网格布局有效",
            "en": "Only applies to grid layout",
            "zh-TW": "僅網格佈局有效"
          }
        },
        {
          "id": "show_logo",
          "type": "switch",
          "label": {
            "zh-CN": "显示 Logo",
            "en": "Show Logo",
            "zh-TW": "顯示 Logo"
          },
          "default": true
        },
        {
          "id": "show_description",
          "type": "switch",
          "label": {
            "zh-CN": "显示描述",
            "en": "Show Description",
            "zh-TW": "顯示描述"
          },
          "default": true
        }
      ]
    }
  ]
}