{
  "id": "hide-until-reply",
  "name": "回复可见",
  "version": "1.1.0",
  "description": "Hide content behind a reply gate with polished lock/unlock UI",
  "author": "Noteva Team",
  "homepage": "https://github.com/noteva26/noteva-plugins",
  "license": "MIT",
  "requires": {
    "noteva": ">=0.2.0"
  },
  "hooks": {
    "frontend": [
      "content_render",
      "comment_after_create"
    ],
    "editor": [
      "toolbar"
    ]
  },
  "shortcodes": [
    "hide-until-reply"
  ],
  "permissions": [
    "read_comments",
    "read_users"
  ],
  "settings": true,
  "database": false
}